# Frontend (NEXT_PUBLIC_*)
NEXT_PUBLIC_PRIVY_APP_ID=
NEXT_PUBLIC_SERVER_URL=http://localhost:8080
NEXT_PUBLIC_SEPOLIA_RPC_URL=https://rpc.sepolia.org
NEXT_PUBLIC_OG_RPC_URL=https://evmrpc-testnet.0g.ai
NEXT_PUBLIC_OG_CHAIN_ID=16602
NEXT_PUBLIC_TAARS_INFT_ADDRESS=
NEXT_PUBLIC_PARENT_ENS_NAME=taars.eth

# Server-only
SERVER_PORT=8080
DEPLOYER_PRIVATE_KEY=
ENCRYPTION_KEY=
SEPOLIA_RPC_URL=https://rpc.sepolia.org
OG_RPC_URL=https://evmrpc-testnet.0g.ai
OG_INDEXER_URL=https://indexer-storage-testnet-turbo.0g.ai
OG_CHAIN_ID=16602
TAARS_INFT_ADDRESS=
PARENT_ENS_NAME=taars.eth
OPENVOICE_URL=http://localhost:5005

# Sepolia billing (TaarsBilling + MockUSDC) — required for end-to-end x402 settlement
TAARS_BILLING_ADDRESS=
MOCK_USDC_ADDRESS=
BILLING_NETWORK_LABEL=sepolia

# KeeperHub — guaranteed onchain execution + audit trail
# Webhook trigger URL pattern. The server replaces `{id}` with the workflow id.
# Verified shape: https://app.keeperhub.com/api/workflows/{id}/webhook
KEEPERHUB_WEBHOOK_BASE=https://app.keeperhub.com/api/workflows/{id}/webhook
# The webhook trigger requires a webhook-specific secret/key (NOT the read API
# key shown on your account API keys page — that returns "Invalid API key
# format" against this endpoint). Find it on each workflow's Webhook trigger
# node in the KeeperHub dashboard.
KEEPERHUB_API_KEY=

# Discord deploy (live)
DISCORD_BOT_TOKEN=
